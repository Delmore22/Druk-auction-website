rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    match /access_codes/{codeId} {
      allow read: if signedIn();

      // Only admins can create fresh access codes.
      allow create: if isAdmin()
        && !exists(/databases/$(database)/documents/access_codes/$(codeId))
        && request.resource.data.status == 'active'
        && request.resource.data.redeemedBy == null
        && request.resource.data.redeemedAt == null;

      // Any signed-in user can redeem exactly one active code for themselves.
      allow update: if signedIn()
        && resource.data.status == 'active'
        && resource.data.redeemedBy == null
        && request.resource.data.status == 'used'
        && request.resource.data.redeemedBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdByEmail == resource.data.createdByEmail
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }
  }
}
