rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(userDocPath())
        && get(userDocPath()).data.role == 'admin';
    }

    match /access_codes/{codeId} {
      allow read: if signedIn();

      // Only admins can create fresh access codes.
      allow create: if isAdmin()
        && !exists(/databases/$(database)/documents/access_codes/$(codeId))
        && request.resource.data.status == 'active'
        && request.resource.data.redeemedBy == null
        && request.resource.data.redeemedAt == null;

      // Any signed-in user can redeem exactly one active code for themselves.
      allow update: if signedIn()
        && resource.data.status == 'active'
        && resource.data.redeemedBy == null
        && request.resource.data.status == 'used'
        && request.resource.data.redeemedBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdByEmail == resource.data.createdByEmail
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());

      // Members can create their own profile but cannot self-promote.
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'member';

      // Members can only stay members; admins can keep admin role.
      allow update: if signedIn()
        && request.auth.uid == userId
        && (
          (resource.data.role == 'admin' && request.resource.data.role == 'admin')
          ||
          (resource.data.role != 'admin' && request.resource.data.role == 'member')
        );

      allow delete: if false;
    }
  }
}
