rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    // Vehicle photos uploaded from Add Vehicle form.
    match /vehicles/{userId}/{allPaths=**} {
      allow write: if signedIn() && request.auth.uid == userId;
      allow read: if signedIn();
    }
  }
}
